---
import { IntellectDashboard } from '../../../modules/about/components/IntellectDashboard';
import intellectProgress from '../../../modules/infra/data/intellect-progress.json';
import BaseLayout from '../../../modules/infra/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
---

<BaseLayout title="Learning" lang={lang}>
  <div class="py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight">
        {lang === 'en' ? 'Learning Path' : '学习路径'}
      </h1>
      <p class="text-muted-foreground mt-2">
        {lang === 'en' 
          ? 'Track your progress across courses and modules.' 
          : '追踪课程和模块的学习进度。'}
      </p>
    </div>
    <IntellectDashboard 
      client:load 
      lang={lang as 'en' | 'zh'} 
      progress={intellectProgress} 
    />
  </div>
</BaseLayout>
