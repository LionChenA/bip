---
import RootLayout from '@/modules/infra/layouts/RootLayout.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
}

const { title, description, image, lang = 'en' } = Astro.props;
---

<RootLayout title={title} description={description} image={image} lang={lang} bodyClass="overflow-hidden">
    <div class="relative z-0 h-full w-full">
        <slot />
    </div>
</RootLayout>
