---
import { ClientRouter } from 'astro:transitions';
import '@fontsource/geist-sans';
import '@fontsource/maple-mono';
import { EntropyGridBackground } from '@/modules/home/components/LandingHero/EntropyGridBackground';
import SEO from '@/modules/infra/components/SEO.astro';
import ThemeProvider from '@/modules/infra/components/ThemeProvider.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  bodyClass?: string;
}

const { title, description, image, lang = 'en', bodyClass = '' } = Astro.props;
---

<html lang={lang}>
	<head>
        <SEO title={title} description={description} image={image} />
        <ClientRouter />
        <ThemeProvider />
	</head>
	<body class:list={[
        "min-h-screen font-sans antialiased bg-background text-foreground transition-colors duration-0",
        bodyClass
    ]}>
        <EntropyGridBackground client:only="react" transition:persist="entropy-grid" transition:name="entropy-grid" />
        <slot />
	</body>
</html>
